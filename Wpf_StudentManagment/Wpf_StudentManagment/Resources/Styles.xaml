<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Основные цвета приложения -->
    <SolidColorBrush x:Key="PrimaryBrush"
                     Color="#2563EB"/>

    <SolidColorBrush x:Key="BorderBrushColor"
                     Color="#D1D5DB"/>

    <SolidColorBrush x:Key="BackgroundBrush"
                     Color="#F8FAFC"/>

    <SolidColorBrush x:Key="CardBrush"
                     Color="White"/>

    <!-- Стиль окна -->
    <Style TargetType="Window">

        <Setter Property="Background"
                Value="{StaticResource BackgroundBrush}" />

        <Setter Property="FontFamily"
                Value="Segoe UI" />

        <Setter Property="FontSize"
                Value="14" />

    </Style>

    <!-- Стиль заголовков и подписей -->
    <Style TargetType="Label">

        <Setter Property="VerticalAlignment"
                Value="Center"/>

        <Setter Property="Margin"
                Value="5"/>

        <Setter Property="FontWeight"
                Value="SemiBold"/>

    </Style>

    <!-- Стиль текстовых полей -->
    <Style TargetType="TextBox">

        <Setter Property="Margin"
                Value="5"/>

        <Setter Property="Padding"
                Value="6"/>

        <Setter Property="Height"
                Value="32"/>

        <Setter Property="BorderBrush"
                Value="{StaticResource BorderBrushColor}"/>

        <Setter Property="BorderThickness"
                Value="1"/>

    </Style>

    <!-- Основной стиль кнопок -->
    <Style TargetType="Button">

        <Setter Property="Margin"
                Value="5"/>

        <Setter Property="Padding"
                Value="12,6"/>

        <Setter Property="Foreground"
                Value="White"/>

        <Setter Property="Background"
                Value="{StaticResource PrimaryBrush}"/>

        <Setter Property="BorderThickness"
                Value="0"/>

        <Setter Property="Cursor"
                Value="Hand"/>

        <Setter Property="FontWeight"
                Value="SemiBold"/>

        <Style.Triggers>

            <!-- Эффект наведения мыши -->
            <Trigger Property="IsMouseOver"
                     Value="True">

                <Setter Property="Opacity"
                        Value="0.9"/>

            </Trigger>

            <!-- Эффект нажатия -->
            <Trigger Property="IsPressed"
                     Value="True">

                <Setter Property="Opacity"
                        Value="0.75"/>

            </Trigger>

        </Style.Triggers>

    </Style>

    <!-- Стиль рамки карточки -->
    <Style x:Key="CardBorderStyle"
           TargetType="Border">

        <Setter Property="Background"
                Value="{StaticResource CardBrush}"/>

        <Setter Property="BorderBrush"
                Value="{StaticResource BorderBrushColor}"/>

        <Setter Property="BorderThickness"
                Value="1"/>

        <Setter Property="CornerRadius"
                Value="6"/>

    </Style>

    <!-- Стиль таблицы студентов -->
    <Style TargetType="DataGrid">

        <Setter Property="Margin"
                Value="0"/>

        <Setter Property="RowHeight"
                Value="35"/>

        <Setter Property="HeadersVisibility"
                Value="Column"/>

        <Setter Property="GridLinesVisibility"
                Value="Horizontal"/>

        <Setter Property="CanUserAddRows"
                Value="False"/>

        <Setter Property="CanUserDeleteRows"
                Value="False"/>

        <Setter Property="IsReadOnly"
                Value="True"/>

    </Style>

</ResourceDictionary>